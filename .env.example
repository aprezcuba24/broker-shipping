# Copiar a `.env` en la raíz del monorepo (junto a docker-compose.yml).
# Docker Compose y la API leen las mismas variables.

# --- PostgreSQL (Compose + servicio API; las URLs se construyen en código) ---
POSTGRES_USER=broker
POSTGRES_PASSWORD=broker
POSTGRES_DB=broker
POSTGRES_HOST=localhost
POSTGRES_PORT=6432

# --- Redis (Compose + API) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- MinIO (Compose) ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- S3 (producción AWS o MinIO local) ---
# En producción deja AWS_ENDPOINT_URL vacío.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
AWS_ENDPOINT_URL=

# Ejemplo local con MinIO (ajusta el puerto si cambias MINIO_API_PORT):
# AWS_ACCESS_KEY_ID=minio
# AWS_SECRET_ACCESS_KEY=minio_secret
# AWS_ENDPOINT_URL=http://localhost:9000
# S3_BUCKET=broker-local

# --- JWT (AuthX; mismos nombres que en Settings / AuthXConfig) ---
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=1440

# --- Tests (opcional): nombre de la base usada por pytest ---
# POSTGRES_DB_TEST=broker_test
