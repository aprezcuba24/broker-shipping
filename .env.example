# Copy to .env and adjust. Used by services/api (load via your app or shell).

DATABASE_URL=postgresql+asyncpg://broker:broker@localhost:5432/broker
# Alembic uses a sync URL (psycopg2)
DATABASE_URL_SYNC=postgresql://broker:broker@localhost:5432/broker
REDIS_URL=redis://localhost:6379/0

# AWS S3 (production) — leave AWS_ENDPOINT_URL empty for default AWS endpoints
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
AWS_ENDPOINT_URL=

# Local MinIO (S3-compatible): set endpoint e.g. http://localhost:9000 and use minio/minio_secret
# AWS_ACCESS_KEY_ID=minio
# AWS_SECRET_ACCESS_KEY=minio_secret
# AWS_ENDPOINT_URL=http://localhost:9000
# S3_BUCKET=broker-local
